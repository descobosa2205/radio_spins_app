# Copia este fichero a .env y rellena los valores reales.
# El .env NO debe versionarse (está en .gitignore).

# Clave secreta de Flask (sesiones y tokens firmados).
# Genera una larga y aleatoria, p.ej.: python -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET_KEY=

# Postgres de Supabase (cadena de conexión con sslmode=require).
DATABASE_URL=

# Supabase (para Storage).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=media

# Colores corporativos (hex).
BRAND_PRIMARY=#1f7ae0
BRAND_ACCENT=#ffd000
